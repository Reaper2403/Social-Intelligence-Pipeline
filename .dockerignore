# ============================================================
# .dockerignore — keep the image slim and secrets out
# ============================================================

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
.eggs/
dist/
build/

# Virtual environment — never ship this, use requirements.txt
.venv/
venv/
env/

# Secrets — NEVER bake into the image
.env

# Git
.git/
.gitignore

# macOS
.DS_Store

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/

# Jupyter notebooks
notebooks/
*.ipynb

# SQLite database — container uses PostgreSQL; SQLite is local-only
data/pipeline.db

# Runtime output files — these are generated by the pipeline and
# mounted as a volume (not needed in image build context)
data/master_reddit_data.json
data/reddit_data.json
data/ai_input_minimal.json
data/ai_analysis_output.json
data/processed_ids.log
data/reported_ids.log

# NOTE: data/config.json and data/system_prompt_final.txt are intentionally
# NOT excluded — they are copied into /app/config/ inside the image.

# Reports — mounted as volumes
reports/

# IDE
.vscode/
.idea/
