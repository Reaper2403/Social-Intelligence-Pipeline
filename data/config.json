{
  "search_settings": {
    "keywords": [
      "time management",
      "productivity",
      "burnout"
    ],
    "target_subreddits": [
      "productivity"
    ],
    "search_all_reddit": false,
    "posts_per_keyword": 10,
    "sort_method": "top",
    "time_filter": "month"
  },
  "export_settings": {
    "format": "json",
    "custom_filename": "reddit_data.json",
    "include_images": true,
    "include_comments": true,
    "max_comments_per_post": 2
  },
  "api_settings": {
    "rate_limit_delay": 1.5,
    "post_processing_delay": 0.8,
    "max_retries": 3
  },
  "filter_settings": {
    "min_score": 20,
    "exclude_nsfw": false,
    "exclude_deleted_posts": true,
    "exclude_deleted_comments": true
  }
}